<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="8dp">

    <!-- Title row -->
    <TextView
        android:id="@+id/week_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="이번 주"
        android:textColor="#FFD54F"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- 7 pre-defined day columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Day 0 (Mon) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:id="@+id/wd0_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="월"
                android:textColor="#888888"
                android:textSize="10sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/wd0_num"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:gravity="center" />
            <View
                android:id="@+id/wd0_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/dot_active"
                android:visibility="invisible" />
            <TextView
                android:id="@+id/wd0_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCC5"
                android:textSize="8sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 1 (Tue) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:id="@+id/wd1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="화"
                android:textColor="#888888"
                android:textSize="10sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/wd1_num"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:gravity="center" />
            <View
                android:id="@+id/wd1_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/dot_active"
                android:visibility="invisible" />
            <TextView
                android:id="@+id/wd1_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCC5"
                android:textSize="8sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 2 (Wed) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:id="@+id/wd2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="수"
                android:textColor="#888888"
                android:textSize="10sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/wd2_num"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="11sp"
