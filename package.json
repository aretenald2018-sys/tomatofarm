{
  "name": "dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "Personal Dashboard with Fitness, Diet, Wine Tracking",
  "main": "app.js",
  "scripts": {
    "start": "node tools/api-server.js",
    "dev": "bash scripts/dev-start.sh",
    "bump": "node scripts/bump-cache.js",
    "build": "node scripts/bump-cache.js && node scripts/copy-www.js",
