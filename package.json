    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "express": "^4.21.0",
    "firebase": "^12.11.0",
    "puppeteer": "^24.40.0"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@seed-design/icon": "^0.6.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2"
  }
